# ~/.config/fish/config.fish - managed by chezmoi

# Disable greeting
set -g fish_greeting

{{ if eq .profile "desktop" -}}
# CachyOS fish configuration
source /usr/share/cachyos-fish-config/cachyos-config.fish

{{ end -}}
# Add local bin to PATH
fish_add_path -g ~/.local/bin

# Mise activation
if type -q mise
    mise activate fish | source
end

# Aliases
alias claude='ANTHROPIC_MODEL=claude-opus-4-7 ENABLE_CLAUDEAI_MCP_SERVERS=false command claude --dangerously-skip-permissions'

# cc — attach to (or create) a persistent tmux session running Claude Code.
function cc --description 'Persistent Claude Code session via tmux'
    # Coder workspaces may run the agent as root; delegate to the bash `cc`, which
    # does the root→vscode hop (Claude refuses --dangerously-skip-permissions as root).
    # No-op on the desktop, where there's no vscode user.
    if test (id -u) -eq 0; and id vscode >/dev/null 2>&1
        exec bash -ic cc
    end
    if not type -q tmux
        claude
        return
    end
    tmux attach -t claude 2>/dev/null; or tmux new -s claude "fish -C claude"
end

# Source local machine-specific config (not managed by dotfiles)
test -f ~/.config/fish/config.local.fish && source ~/.config/fish/config.local.fish
