#!/bin/bash
# Managed by github.com/fx/dotfiles
# Import photos/videos from a PTP/MTP camera to ~/Pictures/Photos organized by date
#
# Usage: camera-import [--dry-run]
#
# Detects the camera via gphoto2, downloads all media files to:
#   ~/Pictures/Photos/YYYY/YYYY-MM-DD/
#
# Uses the camera's file timestamps for date organization.
# Skips files that already exist at the destination.
#
# Requires: gphoto2

set -euo pipefail

DEST="$HOME/Pictures/Photos"
DRY_RUN=false

for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=true ;;
        -h|--help)
            echo "Usage: camera-import [--dry-run]"
            echo "Import photos/videos from camera to ~/Pictures/Photos/YYYY/YYYY-MM-DD/"
            exit 0
            ;;
        *) echo "Unknown option: $arg" >&2; exit 1 ;;
    esac
done

if ! command -v gphoto2 &>/dev/null; then
    echo "Error: gphoto2 not found. Install it first." >&2
    exit 1
fi

# Detect camera
camera=$(gphoto2 --auto-detect 2>/dev/null | tail -n +3 | head -1)
if [[ -z "$camera" ]]; then
    echo "Error: No camera detected. Is it connected and powered on?" >&2
    exit 1
fi

camera_name=$(echo "$camera" | sed 's/  *usb:.*//')
echo "Detected: $camera_name"

# Find DCIM folders. Real cameras typically have /DCIM; Android MTP exposes
# storages at /store_xxxxxxxx/DCIM and the root contains unrelated app data
# that we don't want to traverse (it's slow and trips errors mid-recurse).
# Strategy: probe /DCIM first, then enumerate root storages and probe each.
dcim_folders=()

# Lists immediate child folders of a given path. gphoto2 --list-folders is
# recursive, so we read only until the first sub-folder breadcrumb.
list_children() {
    local parent="$1"
    gphoto2 --list-folders --folder "$parent" 2>/dev/null | awk -v parent="$parent" '
        /^There (is|are) [0-9]+ folder/ {
            if (seen) exit
            match($0, /'"'"'[^'"'"']+'"'"'/)
            current = substr($0, RSTART+1, RLENGTH-2)
            if (current == parent) { seen = 1; next }
            exit
        }
        seen && /^ - / { sub(/^ - /, ""); print }
    '
}

probe() {
    local folder="$1"
    if gphoto2 --list-files --folder "$folder" >/dev/null 2>&1; then
        dcim_folders+=("$folder")
    fi
}

probe "/DCIM"

if [[ ${#dcim_folders[@]} -eq 0 ]]; then
    mapfile -t storages < <(list_children /)
    for storage in "${storages[@]}"; do
        [[ -z "$storage" ]] && continue
        probe "/$storage/DCIM"
    done
fi

if [[ ${#dcim_folders[@]} -eq 0 ]]; then
    echo "No DCIM folder found on device. Is this a camera/phone with photos?" >&2
    exit 1
fi

echo "DCIM folders: ${dcim_folders[*]}"

if $DRY_RUN; then
    echo ""
    for folder in "${dcim_folders[@]}"; do
        echo "Files in $folder:"
        gphoto2 --list-files --folder "$folder" 2>/dev/null | grep "^#" | while read -r line; do
            fname=$(echo "$line" | awk '{print $2}')
            size=$(echo "$line" | awk '{print $4}')
            echo "  $fname (${size} KB)"
        done
    done
    echo ""
    echo "Would be organized into $DEST/YYYY/YYYY-MM-DD/"
    exit 0
fi

# Download directly to organized directories using camera file timestamps
mkdir -p "$DEST"
echo "Downloading and organizing by date..."

output=""
for folder in "${dcim_folders[@]}"; do
    echo "Importing from $folder..."
    folder_output=$(gphoto2 --get-all-files -R --folder "$folder" --skip-existing \
        --filename "$DEST/%Y/%Y-%m-%d/%f.%C" 2>&1)
    output+="$folder_output"$'\n'
done

imported=$(echo "$output" | grep -c "^Saving " || true)
skipped=$(echo "$output" | grep -c "^Skipping " || true)

echo "$output" | grep -E "^(Saving|Skipping) " | while read -r line; do
    echo "  $line"
done

echo ""
echo "Import complete: $imported imported, $skipped skipped."
