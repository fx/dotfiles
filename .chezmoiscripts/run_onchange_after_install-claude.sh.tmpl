#!/bin/bash
# Install Claude Code via mise (global)
# This script runs when its content changes

{{ if .include_defaults -}}
set -e

CLAUDE_BIN="$HOME/.local/bin/claude"

if ! command -v mise >/dev/null 2>&1; then
    echo "⚠️  mise not found, skipping Claude Code install"
    exit 0
fi

# claude-code is a mise-managed tool: its binary lives under mise's install dir
# with a shim in ~/.local/share/mise/shims, NOT at ~/.local/bin/claude. Verify
# with `mise which` (works without mise being activated on PATH), falling back to
# a direct ~/.local/bin install. Checking only $CLAUDE_BIN false-negatives and
# aborts the chezmoi run before later scripts (e.g. settings.json) can execute.
claude_installed() { [ -x "$CLAUDE_BIN" ] || mise which claude >/dev/null 2>&1; }

if claude_installed; then
    echo "✓ Claude Code already installed"
    exit 0
fi

echo "Installing Claude Code via mise..."
mise use -g claude-code@latest

if claude_installed; then
    echo "✓ Claude Code installed successfully"
else
    echo "⚠️  Claude Code installation may have failed"
    exit 1
fi
{{ end -}}
